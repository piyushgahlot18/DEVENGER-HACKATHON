# Civic AI environment variables
#
# For Vercel production:
# 1. Set VITE_AI_PROVIDER=server.
# 2. Add one private provider key in Vercel Project Settings -> Environment Variables.
# 3. Do not expose real API keys with VITE_* variables in production.

# Frontend provider mode:
# - server: recommended for Vercel. Calls /api/ai/chat and keeps keys private.
# - mock: offline demo responses.
# - gemini/openai: direct browser calls for local demos only. These expose keys.
VITE_AI_PROVIDER=server

# Private Vercel serverless provider config.
# Add these in Vercel, not in committed code.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Alternative: OpenAI or OpenAI-compatible APIs.
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini

# Optional serverless generation controls.
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# Local-only direct browser provider examples.
# VITE_AI_PROVIDER=gemini
# VITE_GEMINI_API_KEY=your_local_demo_key
# VITE_GEMINI_MODEL=gemini-2.0-flash
#
# VITE_AI_PROVIDER=openai
# VITE_OPENAI_API_KEY=your_local_demo_key
# VITE_OPENAI_BASE_URL=https://api.openai.com
# VITE_OPENAI_MODEL=gpt-4o-mini
